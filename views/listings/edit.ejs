<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-8 offset-2">

            <body>
                <h1>EDIT YOUR LISTINGS</h1>
                <form method="post" action="/listings/<%= listing._id %>?_method=PUT" novalidate
                    class="needs-validation" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-lable">Title</label>
                        <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control"
                            required>
                    </div>

                    <div class="mb-3">
                        <label class="form-lable">Description</label>
                        <textarea name="listing[description]" rows="5" class="form-control"
                            required><%= listing.description %></textarea>
                    </div>

                    <div class="mb-3">
                        Original Image<br>
                        <img src="<%=originalImageUrl%>" class="edit-image-preview">
                    </div>

                    <div class="mb-3">
                        <label class="form-lable">Upload New Image</label>
                        <input name="image" type="file" class="form-control">
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label class="form-lable">Price</label>
                            <input name="listing[price]" value="<%= listing.price %>" type="number" class="form-control"
                                required>
                        </div>
                        <div class="mb-3 col-md-8">
                            <label class="form-lable">Country</label>
                            <input name="listing[country]" value="<%= listing.country %>" type="text"
                                class="form-control" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-lable">Location</label>
                        <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control"
                            required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label"><strong>Categories</strong></label>
                        <div class="d-flex flex-wrap gap-3">
                            <% let c=listing.categories || []; let cats=["Trending", "Rooms" , "Iconic Cities"
                                , "Mountain" , "Castles" , "Amazing Pools" , "Camping" , "Farms" , "Arctic"
                                , "River Side" , "Domes" , "Boats" , "Beach" , "Snow" , "Forest" ]; let
                                icons={ "Trending" : "fa-solid fa-fire-flame-curved" , "Rooms" : "fa-solid fa-bed"
                                , "Iconic Cities" : "fa-solid fa-city" , "Mountain" : "fa-solid fa-mountain-city"
                                , "Castles" : "fa-brands fa-fort-awesome" , "Amazing Pools"
                                : "fa-solid fa-person-swimming" , "Camping" : "fa-solid fa-tent-arrow-down-to-line"
                                , "Farms" : "fa-solid fa-building-wheat" , "Arctic" : "fa-regular fa-snowflake"
                                , "River Side" : "fa-solid fa-water" , "Domes" : "fa-solid fa-igloo" , "Boats"
                                : "fa-solid fa-ship" , "Beach" : "fa-solid fa-umbrella-beach" , "Snow"
                                : "fa-solid fa-snowflake" , "Forest" : "fa-solid fa-tree" }; %>
                                <% for(let cat of cats) { %>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="listing[categories]"
                                            value="<%= cat %>" id="<%= cat.replace(/\s+/g, '-') %>" <%=c.includes(cat)
                                            ? 'checked' : '' %>>
                                        <label class="form-check-label" for="<%= cat.replace(/\s+/g, '-') %>">
                                            <i class="<%= icons[cat] %>"></i>
                                            <%= cat %>
                                        </label>
                                    </div>
                                    <% } %>
                        </div>
                    </div>

                    <button class="btn btn-dark add-btn mt-3">EDIT</button>
                    <br><br><br>
                </form>
            </body>
        </div>
    </div>